# Copy to .env.local and fill in values
# Backend reads from backend/.env or environment variables

# -- Database --------------------------------------------------
DATABASE_URL=postgresql+asyncpg://cloudcost:localdev@localhost:5432/cloudcost

# -- Redis -----------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -- JWT (generate with: openssl rand -hex 64) ----------------
JWT_SECRET_KEY=replace-with-64-byte-random-hex-from-openssl-rand-hex-64
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -- CORS ------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000"]

# -- Admin bootstrap (run seed_admin once) --------------------
FIRST_ADMIN_EMAIL=admin@yourdomain.com
FIRST_ADMIN_PASSWORD=change-me-strong-password

# -- App -------------------------------------------------------
APP_ENV=development
DEBUG=false

# -- Frontend --------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1

# CloudCost — environment variable template
# Copy to .env.local (Docker path) or backend/.env (manual path) and fill in values.
# Never commit a file that contains real credentials.

# ─── Core ─────────────────────────────────────────────────────────────────────
APP_ENV=development                       # development | production
DEBUG=false                               # Enable verbose debug logging

# ─── Database ─────────────────────────────────────────────────────────────────
# Required. Must use the asyncpg driver prefix.
DATABASE_URL=postgresql+asyncpg://cloudcost:localdev@localhost:5432/cloudcost

# ─── Redis ────────────────────────────────────────────────────────────────────
# Required.
REDIS_URL=redis://localhost:6379/0

# ─── Security ─────────────────────────────────────────────────────────────────
# Required. Generate with: openssl rand -hex 64
JWT_SECRET_KEY=replace-with-64-byte-random-hex-from-openssl-rand-hex-64
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60        # Access token lifetime in minutes
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7           # Refresh token lifetime in days

# ─── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. Add your frontend URL in production.
CORS_ORIGINS=["http://localhost:3000"]

# ─── Admin Bootstrap ──────────────────────────────────────────────────────────
# Used by the seed_admin script (python -m app.scripts.seed_admin).
# Required when running the seed script; not needed at runtime.
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change-me-strong-password

# ─── Azure Cost Management ────────────────────────────────────────────────────
# Required for live Azure billing data. All four AZURE_* vars must be set together.
# Create a service principal with the Cost Management Reader role:
#   az ad sp create-for-rbac --name cloudcost-sp --role "Cost Management Reader" \
#     --scopes /subscriptions/<your-subscription-id>
#
# Set MOCK_AZURE=true to skip real Azure API calls and use synthetic data instead
# (recommended for local development without Azure access).
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-app-registration-client-id
AZURE_CLIENT_SECRET=your-azure-app-registration-client-secret
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_SUBSCRIPTION_SCOPE=                 # Optional: computed from AZURE_SUBSCRIPTION_ID if blank
MOCK_AZURE=true                           # true = use synthetic data; false = use real Azure API

# ─── AI / LLM Recommendations ─────────────────────────────────────────────────
# Required for AI-powered cost recommendations. Leave blank to disable AI features.
# Get your Anthropic API key at: https://console.anthropic.com
ANTHROPIC_API_KEY=                        # e.g. sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6         # Claude model ID to use

# Optional: Azure OpenAI as an alternative to Anthropic
AZURE_OPENAI_ENDPOINT=                    # e.g. https://{resource}.openai.azure.com/
AZURE_OPENAI_API_KEY=                     # Azure OpenAI API key
AZURE_OPENAI_DEPLOYMENT=gpt-4o            # Azure OpenAI deployment name

LLM_DAILY_CALL_LIMIT=100                  # Maximum AI API calls per day
LLM_MIN_MONTHLY_SPEND_THRESHOLD=50.0      # Minimum monthly spend (USD) to qualify for AI analysis

# ─── SMTP / Email Notifications ───────────────────────────────────────────────
# Optional. Leave blank to disable email notifications.
# Compatible with SendGrid, SES, Azure Communication Services, or any SMTP server.
SMTP_HOST=                                # SMTP server hostname, e.g. smtp.sendgrid.net
SMTP_PORT=587                             # SMTP port (587 for STARTTLS, 465 for TLS)
SMTP_USER=                                # SMTP authentication username
SMTP_PASSWORD=                            # SMTP authentication password
SMTP_FROM=noreply@example.com             # Sender address for outgoing emails
SMTP_START_TLS=true                       # true = use STARTTLS

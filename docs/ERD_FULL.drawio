    <!-- Legend row 3: PK prefix -->
    <mxCell id="legend-3" value="PK    =  Primary Key (surrogate UUID)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;fontSize=11;" vertex="1" parent="legend-title">
      <mxGeometry x="10" y="102" width="530" height="22" as="geometry"/>
    </mxCell>

    <!-- Legend row 4: FK prefix -->
    <mxCell id="legend-4" value="FK    =  Foreign Key (hard constraint with ON DELETE behavior)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;fontSize=11;" vertex="1" parent="legend-title">
      <mxGeometry x="10" y="124" width="530" height="22" as="geometry"/>
    </mxCell>

    <!-- Legend row 5: UK prefix -->
    <mxCell id="legend-5" value="UK    =  Unique Key (UNIQUE constraint)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;fontSize=11;" vertex="1" parent="legend-title">
      <mxGeometry x="10" y="146" width="530" height="22" as="geometry"/>
    </mxCell>

    <!-- Legend row 6: *ref prefix -->
    <mxCell id="legend-6" value="*ref  =  Logical/Soft Reference (no FK constraint — highlighted pink)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;fontSize=11;" vertex="1" parent="legend-title">
      <mxGeometry x="10" y="168" width="530" height="22" as="geometry"/>
    </mxCell>

    <!-- Legend row 7: *FK prefix -->
    <mxCell id="legend-7" value="*FK   =  Soft FK — string-match join (no database constraint)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;fontSize=11;" vertex="1" parent="legend-title">
